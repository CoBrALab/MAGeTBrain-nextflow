params {
    primarySpectra = 'T1w'
    inputDir = "${projectDir}/inputs"
    outputDir = "${projectDir}/output"
    custom_config_version = 'master'
    custom_config_base = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_description = 'Standard MAGeTBrain workflow'  // Default fallback

}
try {
    includeConfig "${params.custom_config_base}/nfcore_custom.config"
} catch (Exception e) {
    System.err.println("WARNING: Could not load nf-core/configs")
}


profiles {
    standard {
      process {
        container = 'ghcr.io/cobralab/magetbrain-nextflow:master'
        executor = 'local'
      }
      apptainer {
          enabled = true
          pullOptions = '--max-tries 3 --retry 5'
          pullTimeout = '10m'
      }
    }

alliance_extended {
    params {
        max_cpus = 192
    }
    process {
        resourceLimits = [memory: '749 GB', cpus: 192, time: '7d']
        withName: registerAffine {
            cpus = 192
            time = '15.min'
        }
        withName: registerNonlinear {
            cpus = 192
            time = '30.min'
        }
        withName: resampleLabel {
            cpus = 192
            time = '15.min'
        }
        withName: majorityVote {
            cpus = 192
            time = '15.min'
        }
    }
}}

process {
  errorStrategy = 'finish'
  cache = 'lenient'
}

report {
  enabled = true
}

dag {
  enabled = true
  verbose = true
}

timeline {
  enabled = true
}
